{
  "expo": {
    "name": "Municip'All",
    "slug": "municipall",
    "scheme": "municipall",
    "version": "1.0.0",
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/logo_app.png",
          "color": "#0B0080",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Autorisez l'accès à vos photos pour joindre une preuve à votre signalement.",
          "cameraPermission": "Autorisez l'accès à l'appareil photo pour joindre une preuve à votre signalement."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Autorisez la localisation pour positionner votre signalement sur la carte."
        }
      ]
    ],
    "orientation": "portrait",
    "icon": "./assets/logo_app.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F2F2F7"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "municipall.v2"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo_app.png",
        "backgroundColor": "#ffffff"
      },
      "package": "municipall.v2"
    }
  }
}
